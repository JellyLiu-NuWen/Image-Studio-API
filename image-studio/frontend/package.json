{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:windows": "vite --mode windows",
    "dev:macos": "vite --mode macos",
    "dev:linux": "vite --mode linux",
    "build": "tsc --noEmit && vite build",
    "build:windows": "tsc --noEmit && vite build --mode windows",
    "build:macos": "tsc --noEmit && vite build --mode macos",
    "build:linux": "tsc --noEmit && vite build --mode linux",
    "preview": "vite preview"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "konva": "^9.3.22",
    "lucide-react": "^0.471.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.16",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
