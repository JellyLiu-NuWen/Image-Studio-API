# Required. Used only for /admin and /api/config.
ADMIN_TOKEN=change-me-admin-token

# Optional when configured through the admin page.
IMAGE_API_TOKEN=change-me-client-token
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_API_KEY=sk-change-me

# Optional defaults for clients that omit these fields.
DEFAULT_IMAGE_MODEL=gpt-image-2
DEFAULT_TEXT_MODEL=gpt-5.5
DEFAULT_IMAGE_SIZE=1024x1024
DEFAULT_IMAGE_QUALITY=auto
DEFAULT_OUTPUT_FORMAT=png

# Runtime.
HOST=0.0.0.0
PORT=8787
CONFIG_PATH=data/config.json
REQUEST_TIMEOUT_SECONDS=120
MAX_CONCURRENT_REQUESTS=1
RATE_LIMIT_PER_MINUTE=10
